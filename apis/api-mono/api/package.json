{
  "name": "api-mono",
  "description": "",
  "version": "0.0.1",
  "private": true,
  "author": "<add your company or personal name here>",
  "scripts": {
    "build": "tsc && tsc-alias",
    "cli-script": "VERBOSE=true && node ./build/server.js -r ",
    "dev:start": "tsc-watch --preserveWatchOutput --onSuccess 'sh -c \"npx tsc-alias && npm start\"'",
    "lint": "eslint 'src/**/*.{js,ts,tsx}'",
    "lint:fix": "npm run lint -- --fix",
    "start": "node ./build/server.js",
    "test": "npm run lint && npm run test:unit",
    "test:unit": "ENVIRONMENT=test vitest run",
    "test:unit:watch": "ENVIRONMENT=test vitest",
    "migrate-mongo": "migrate-mongo",
    "migration:create": "migrate-mongo create",
    "migration:up": "migrate-mongo up",
    "migration:down": "migrate-mongo down",
    "migration:status": "migrate-mongo status",
    "generate:server": "generate-it ../api-spec/release/api-spec.yml --yes -t git@github.com:j-d-carmichael/generate-it-mono-express-mongo.git"
  },
  "dependencies": {
    "@typegoose/typegoose": "~13.2.0",
    "celebrate": "^15.0.3",
    "command-line-args": "^5.2.0",
    "cors": "^2.8.5",
    "custom-error": "^0.2.1",
    "dotenv": "^16.4.5",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "express-form-data": "^3.0.1",
    "helmet": "^7.1.0",
    "@workos-inc/node": "^7.0.0",
    "lodash": "^4.18.1",
    "load-mongoose": "^4.0.0",
    "migrate-mongo": "^14.0.7",
    "mongoose": "~9.2.2",
    "morgan": "^1.10.0",
    "nunjucks-emailer": "^5.0.0",
    "node-worker-threads-pool": "^1.5.1",
    "object-reduce-by-map": "^3.3.0",
    "proc-env-helper": "^1.1.0",
    "recursive-readdir-sync": "^1.0.6",
    "request-ip": "^3.3.0",
    "source-map-support": "^0.5.21",
    "tslib": "^2.6.3",
    "winston": "^3.13.1",
    "worker-farm": "^1.7.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/command-line-args": "^5.2.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-form-data": "^2.0.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/lodash": "^4.17.7",
    "@types/migrate-mongo": "^10.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.14",
    "@types/request-ip": "^0.0.41",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/validator": "^13.12.0",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^5.47.0",
    "@typescript-eslint/parser": "^5.47.0",
    "eslint": "^8.30.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-deprecate": "^0.7.0",
    "eslint-plugin-prettier": "^4.0.0",
    "vitest": "^3.1.1",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.10",
    "tsc-watch": "^6.2.0",
    "typescript": "~5.5.4",
    "generate-it": "^5.62.4"
  },
  "mockingServer": false
